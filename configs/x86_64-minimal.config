# jvmlab minimal kernel hardening fragment (x86_64).
#
# This file is a Linux kconfig *fragment*, not a full .config. It is
# merged on top of `make defconfig` by minimal.sh using
# scripts/kconfig/merge_config.sh, followed by `make olddefconfig` so
# the kernel resolves dependencies (everything gated on NET, MODULES,
# etc. collapses automatically).
#
# Each directive is grouped by intent and gets a short rationale. When
# bumping the kernel, re-read this file end to end: a flag that has
# been renamed upstream becomes a silent no-op after the merge.
#
# -----------------------------------------------------------------
# 1. Attack-surface reduction: remove subsystems the appliance never
#    uses so they cannot be reached by a local attacker or a bug.
# -----------------------------------------------------------------

# No networking. Nothing in the ISO talks to the network; removing the
# whole stack drops IPv4/IPv6/netfilter/sockets/tls from the TCB.
# Consequence: socket(2) returns -EAFNOSUPPORT.
# CONFIG_NET is not set

# No runtime module loading. The kernel is monolithic; this removes
# init_module / finit_module / kmod entirely, so a root exploit cannot
# gain code execution by loading an LKM.
# CONFIG_MODULES is not set

# No kexec. We do not chain-load other kernels from userspace.
# CONFIG_KEXEC is not set
# CONFIG_KEXEC_FILE is not set

# /dev/mem and /dev/port were historically used for userspace to poke
# physical memory/IO ports. Not needed by anything we ship.
# CONFIG_DEVMEM is not set
# CONFIG_DEVPORT is not set

# Magic SysRq lets a console user trigger kernel operations (crashdump,
# kill-all, reboot). Useful for debug, dangerous as a default.
# CONFIG_MAGIC_SYSRQ is not set

# Diagnostic filesystems expose kernel internals to userspace.
# CONFIG_DEBUG_FS is not set
# CONFIG_PROC_KCORE is not set

# Dynamic instrumentation primitives; they're a recurring CVE source
# and we have no tracing workflow on the appliance.
# CONFIG_KPROBES is not set
# CONFIG_UPROBES is not set

# BPF from userspace has shipped a steady stream of LPEs and is not
# used anywhere in this image.
# CONFIG_BPF_SYSCALL is not set
# CONFIG_BPF_JIT is not set

# User namespaces are a prime privilege-escalation surface and make no
# sense in a single-user, single-UID appliance.
# CONFIG_USER_NS is not set

# io_uring has repeatedly shipped kernel-LPE CVEs. We don't use it.
# CONFIG_IO_URING is not set

# No suspend/hibernate on a ROM-like appliance.
# CONFIG_HIBERNATION is not set
# CONFIG_SUSPEND is not set

# 32-bit compatibility syscall paths. Disabling IA32_EMULATION drops
# the int $0x80 / sysenter entry points plus the compat syscall table.
# CONFIG_IA32_EMULATION is not set

# Ancient vsyscall page. Modern glibc/musl use vDSO; this is gadget
# fodder for ret2libc-style exploits.
# CONFIG_X86_VSYSCALL_EMULATION is not set

# Legacy /dev/tty* PTYs; devpts (/dev/ptmx) is the modern interface.
# CONFIG_LEGACY_PTYS is not set

# Kernel auditd feed. There's no userspace reader in the image.
# CONFIG_AUDIT is not set

# binfmt_misc runs arbitrary interpreters based on magic bytes. Not used.
# CONFIG_BINFMT_MISC is not set

# -----------------------------------------------------------------
# 2. Positive hardening: enable kernel self-protections. Most of these
#    are already on in x86_64 defconfig; listing them here pins the
#    intent so a future defconfig change can't regress us silently.
# -----------------------------------------------------------------

# Stack canaries on every function with a local buffer.
CONFIG_STACKPROTECTOR=y
CONFIG_STACKPROTECTOR_STRONG=y

# Compile-time overflow checks on mem/str* functions.
CONFIG_FORTIFY_SOURCE=y

# Zero every function's on-stack locals on entry (plugs infoleaks and
# cheapens exploit primitives that rely on stale stack data).
CONFIG_INIT_STACK_ALL_ZERO=y

# Initialise heap allocations on alloc and free by default.
CONFIG_INIT_ON_ALLOC_DEFAULT_ON=y
CONFIG_INIT_ON_FREE_DEFAULT_ON=y

# Reject bad pointer/size combos in copy_from_user / copy_to_user.
CONFIG_HARDENED_USERCOPY=y

# Randomised + hardened slab freelists make UAF exploitation harder.
CONFIG_SLAB_FREELIST_RANDOM=y
CONFIG_SLAB_FREELIST_HARDENED=y

# KASLR and physical memory layout randomisation.
CONFIG_RANDOMIZE_BASE=y
CONFIG_RANDOMIZE_MEMORY=y

# Require CAP_SYSLOG to read the kernel ring buffer. Unprivileged
# users cannot dmesg.
CONFIG_SECURITY_DMESG_RESTRICT=y

# Catch stack overflows and corrupt list heads at runtime.
CONFIG_SCHED_STACK_END_CHECK=y
CONFIG_BUG_ON_DATA_CORRUPTION=y

# Security framework + Yama (ptrace_scope).
CONFIG_SECURITY=y
CONFIG_SECURITY_YAMA=y

# Kernel strict RWX: code is RX, rodata is RO, no W^X violations.
CONFIG_STRICT_KERNEL_RWX=y
